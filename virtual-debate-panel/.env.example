# =============================================================================
# Virtual Debate Panel - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# Choose: 'gemini', 'openai', or 'anthropic'
LLM_PROVIDER=gemini

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo
OPENAI_ORG_ID=

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# -----------------------------------------------------------------------------
# Vector Database Configuration
# -----------------------------------------------------------------------------
# Choose: 'chromadb' (local) or 'pinecone' (cloud)
VECTOR_DB=chromadb

# ChromaDB (Local)
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=author_library

# Pinecone (Cloud)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=virtual-debate-panel

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
# For Gemini: text-embedding-004
# For OpenAI: text-embedding-3-large or text-embedding-ada-002
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# Semantic Router Configuration
# -----------------------------------------------------------------------------
# Minimum cosine similarity to include author (0.0 - 1.0)
RELEVANCE_THRESHOLD=0.7

# Panel size constraints
MIN_AUTHORS=2
MAX_AUTHORS=5

# Fallback behavior if no authors meet threshold
FALLBACK_TO_TOP_AUTHORS=true
FALLBACK_AUTHOR_COUNT=3

# -----------------------------------------------------------------------------
# RAG Pipeline Configuration
# -----------------------------------------------------------------------------
# Number of chunks to retrieve per author
TOP_K_CHUNKS=5

# Chunk size for text splitting
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Maximum tokens in LLM response
MAX_RESPONSE_TOKENS=300

# Temperature for LLM generation (0.0 - 1.0)
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# Authentication (optional)
ENABLE_AUTH=false
API_KEY=

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# Enable debug mode (verbose logging)
DEBUG=false

# -----------------------------------------------------------------------------
# Data Paths
# -----------------------------------------------------------------------------
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
DATA_EMBEDDINGS_DIR=./data/embeddings

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------
# Timeout for LLM API calls (seconds)
LLM_TIMEOUT=30

# Maximum concurrent author queries
MAX_CONCURRENT_AUTHORS=5

# Retry configuration
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2
